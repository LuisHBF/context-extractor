<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.contextextractor.presentation.steps.AdditionalContextStepController"
            styleClass="step-pane">

    <center>
        <ScrollPane styleClass="step-scroll" fitToWidth="true">
            <VBox styleClass="step-content" spacing="16">
                <Label text="Additional Context" styleClass="step-section-title"/>
                <Label text="Add any extra information, business rules, or instructions for the AI."
                       styleClass="step-description" wrapText="true"/>
                <TextArea fx:id="contextArea"
                          promptText="Type anything you want the AI to know about this project..."
                          wrapText="true"
                          styleClass="preview-area"
                          prefHeight="340"/>
                <Label fx:id="charCountLabel" text="0 characters" styleClass="step-description"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="step-nav-bar" alignment="CENTER_LEFT" spacing="12">
            <Button fx:id="backButton" text="← Back" styleClass="back-button" onAction="#onBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="nextButton" text="Next →" styleClass="next-button" onAction="#onNext"/>
        </HBox>
    </bottom>

</BorderPane>
