<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.contextextractor.presentation.steps.DirectoryStepController"
            styleClass="step-pane">

    <center>
        <ScrollPane fitToWidth="true" styleClass="step-scroll">
            <VBox styleClass="step-content" spacing="24">

                <VBox spacing="6">
                    <Label text="Select Project Directory" styleClass="step-section-title"/>
                    <Label text="Select a package or module directory. All files will be scanned recursively."
                           styleClass="step-description" wrapText="true"/>
                </VBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="directoryPathField"
                               promptText="No directory selected"
                               editable="false"
                               HBox.hgrow="ALWAYS"/>
                    <Button text="Browse…" styleClass="browse-button" onAction="#onBrowse"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <ProgressIndicator fx:id="progressIndicator"
                                       prefWidth="40" prefHeight="40"
                                       visible="false" managed="false"/>
                </HBox>

                <VBox fx:id="summaryBox" spacing="12" visible="false" managed="false">
                    <HBox spacing="24" alignment="CENTER_LEFT">
                        <Label fx:id="filesFoundLabel" styleClass="files-found-label"/>
                        <Label fx:id="filesSkippedLabel" styleClass="files-skipped-label"/>
                    </HBox>
                    <Label fx:id="noFilesLabel"
                           text="No readable files found in this directory."
                           styleClass="warning-label"
                           visible="false" managed="false"/>
                    <ListView fx:id="fileListView" prefHeight="300" VBox.vgrow="ALWAYS"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="step-nav-bar" alignment="CENTER_LEFT" spacing="12">
            <Button fx:id="backButton" text="← Back" styleClass="back-button" onAction="#onBack"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="nextButton" text="Next →" styleClass="next-button" onAction="#onNext"/>
        </HBox>
    </bottom>

</BorderPane>
